# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://username:password@localhost:5432/haveniq

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=30d

# ── Email (SendGrid) ──────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@haveniq.com
FROM_NAME=HavenIQ

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:8081

# ── File Storage (optional — Cloudinary for profile photos) ──────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
